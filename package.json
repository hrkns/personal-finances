{
  "name": "personal-finances",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "start": "go run .",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "eslint .",
    "lint:frontend:fix": "eslint . --fix",
    "lint:backend": "node scripts/lint-go.js",
    "lint:backend:fmtcheck": "node scripts/lint-go.js --fmtcheck",
    "lint:backend:fix": "gofmt -s -w ./main.go ./backend",
    "test:frontend": "node scripts/run-node-tests.js web all",
    "test:frontend:unit": "node scripts/run-node-tests.js web unit",
    "test:frontend:integration": "node scripts/run-node-tests.js web integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:backend": "go test -v ./backend/..."
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.54.1",
    "eslint": "^9.22.0",
    "jsdom": "^26.1.0"
  }
}
